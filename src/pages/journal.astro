---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostListWithThumbnails from '../components/PostListWithThumbnails.astro';
import { getCollection } from 'astro:content';

// Get all blog posts and sort them by date
const allPosts = await getCollection('posts');
const sortedPosts = allPosts.sort((a, b) => {
  return new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf();
});

// Format posts for the PostList component
const posts = sortedPosts.map(post => ({
  ...post,
  url: `/posts/${post.id}`,
  frontmatter: post.data
}));
---

<BaseLayout title="Journal">
  <div class="max-w-3xl mx-auto">
    <header class="mb-12 text-center" transition:animate="fade">
      <h1 class="text-5xl mb-4">技术文章</h1>
      <p class="text-xl text-muted-foreground">
        围绕后端架构、数据库、缓存、消息队列和 AI 工程化的学习与实践记录。
      </p>
    </header>

    <div transition:animate="fade">
      <PostListWithThumbnails posts={posts} showTags={true} title="All Posts" />
    </div>
  </div>
</BaseLayout>
